### Go ###
# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work

# End of https://www.toptal.com/developers/gitignore/api/go
/snb
/tethux

# Local task and development state
/.air/
/.last_run
/.local/
/bin/
/data/
/artifacts/
/ingestion/
/results/
/tmp/

# Logs, coverage, and local databases
*.log
*.pid
*.prof
*.sqlite
*.sqlite3
coverage/
coverage.out

# CI viewer generated frontend output and dependencies
/tools/ci-results/viewer/frontend/.svelte-kit/
/tools/ci-results/viewer/frontend/build/*
!/tools/ci-results/viewer/frontend/build/.gitkeep
/tools/ci-results/viewer/frontend/node_modules/
